# Provider selection: auto | openai | ollama | huggingface
CHAT_PROVIDER=auto
EMBEDDINGS_PROVIDER=auto

# OpenAI (recommended cloud quality)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Ollama (recommended local/free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b-instruct
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Hugging Face Inference API (cloud/free-tier)
HUGGINGFACE_API_KEY=
HUGGINGFACE_CHAT_MODEL=HuggingFaceH4/zephyr-7b-beta
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HUGGINGFACE_MAX_NEW_TOKENS=512
CHAT_TEMPERATURE=0.1

# Chroma
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=codemind

# Chunking / retrieval
CHUNK_SIZE=1500
CHUNK_OVERLAP=200
RETRIEVER_SEARCH_TYPE=mmr
RETRIEVER_K=6
RETRIEVER_FETCH_K=20

# API
HOST=0.0.0.0
PORT=8765
LOG_LEVEL=INFO
LOG_FORMAT=json
CORS_ORIGINS=["*"]
