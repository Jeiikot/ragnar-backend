# Global Ragnar ignore rules (applied to uploaded ZIP contents)
# These are additional safety/performance filters on top of project .gitignore files.

# Directories
.git/
.github/
__pycache__/
node_modules/
.venv/
venv/
.tox/
.idea/
.vscode/
.mypy_cache/
.pytest_cache/
.ruff_cache/
dist/
build/
.next/
.nuxt/
.output/
coverage/
.terraform/
.serverless/

# Binary extensions
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.ico
*.svg
*.webp
*.tiff
*.woff
*.woff2
*.ttf
*.otf
*.eot
*.pdf
*.zip
*.tar
*.gz
*.bz2
*.xz
*.7z
*.rar
*.exe
*.dll
*.so
*.dylib
*.bin
*.pyc
*.pyo
*.class
*.o
*.obj
*.wasm
*.mp3
*.mp4
*.avi
*.mov
*.wav
*.flac
*.ogg
*.webm
*.sqlite
*.db
*.sqlite3
.DS_Store

# Generated/noisy files
package-lock.json
yarn.lock
pnpm-lock.yaml
Pipfile.lock
poetry.lock
composer.lock
Gemfile.lock
Cargo.lock
go.sum
*.min.js
*.min.css
*.map
.gitignore
.gitattributes
.gitmodules
.dockerignore
.editorconfig
.prettierrc
.eslintignore
.stylelintrc
.pre-commit-config.yaml
.flake8
.coverage
.coveragerc

# Sensitive material
.env
.env.*
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
credentials.json
secrets.json
secrets.yaml
secrets.yml
*.secret
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
.htpasswd
.npmrc
.pypirc
*.keystore
token.json
